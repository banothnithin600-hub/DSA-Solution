class Solution {
public:
    vector<int> findThePrefixCommonArray(vector<int>& A, vector<int>& B) {
    int n = A.size();
     //unordered_map<int,int>m;
     vector<int>m(n+1,0);
     vector<int>ans(n);
     int count = 0;
     for(int i=0;i<n;i++){
        m[A[i]]++;
        if(m[A[i]]==2) count++;

        m[B[i]]++;
        if(m[B[i]]==2) count++;
         

          ans[i]=count;
     }
     return ans;
    }
};
